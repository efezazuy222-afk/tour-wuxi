---
export interface FooterLink {
  label: string;
  href?: string;
}

export interface FooterSection {
  title: string;
  links?: FooterLink[];
  items?: string[];
  description?: string;
  span?: number;
}

export interface FooterProps {
  backgroundImage: string;
  about: {
    title: string;
    description: string;
  };
  navigation: FooterLink[];
  destinations: string[];
  copyright: string;
}

const props = Astro.props as FooterProps;
const {
  backgroundImage,
  about,
  navigation,
  destinations,
  copyright,
} = props;
---

<footer class="relative mb-4 overflow-hidden">
  <div class="relative mx-auto max-w-6xl px-4">
    <div
      class="relative overflow-hidden rounded-3xl bg-slate-900/40 p-10 text-white backdrop-blur"
      style={`background-image:url('${backgroundImage}'); background-size:cover; background-position:center;`}
    >
      <!-- Overlay -->
      <div class="absolute inset-0 bg-linear-to-t from-black/90 to-blue-950/85"></div>

      <!-- Content -->
      <div class="relative grid grid-cols-1 gap-10 md:grid-cols-4">
        <!-- About -->
        <div class="md:col-span-2 md:pe-12">
          <h3 class="mb-4 text-lg font-semibold">
            {about.title}
          </h3>
          <p class="leading-relaxed text-white/70">
            {about.description}
          </p>
        </div>

        <!-- Navigation -->
        <div>
          <h3 class="mb-4 text-lg font-semibold">Navigation</h3>
          <ul class="space-y-2 text-white/80">
            {navigation.map((item) => (
              <li>
                {item.href ? (
                  <a
                    href={item.href}
                    class="transition hover:text-white"
                  >
                    {item.label}
                  </a>
                ) : (
                  <span>{item.label}</span>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Popular Destinations -->
        <div>
          <h3 class="mb-4 text-lg font-semibold">Popular Destinations</h3>
          <ul class="space-y-2 text-white/80">
            {destinations.map((place) => (
              <li>{place}</li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Copyright -->
      <div class="relative mt-8 w-full py-4">
        <div class="mx-auto max-w-6xl px-4 text-center text-sm text-white">
          <p>{copyright}</p>
        </div>
      </div>
    </div>
  </div>
</footer>