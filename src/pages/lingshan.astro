---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>灵山大佛导游讲解_无锡佛教文化之旅_澜青旅行社</title>
  <meta name="description" content="澜青旅行社提供灵山大佛专业导游讲解服务，了解佛教文化，感受88米青铜大佛的震撼。包含九龙灌浴、梵宫参观、佛脚抱抱等体验。" />
  <meta name="keywords" content="灵山大佛导游,无锡佛教旅游,灵山胜境,九龙灌浴,梵宫" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --primary: #1a6b52; --dark: #0f172a; --text: #1e293b; --text-light: #64748b;
      --bg: #f8fafc; --white: #fff; --border: #e2e8f0; --shadow: 0 4px 24px rgba(0,0,0,0.06); --radius: 12px;
    }
    body { font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif; color: var(--text); line-height: 1.7; background: var(--bg); }
    
    .hero { background: linear-gradient(160deg, #4a1a0f, #8b4513, #c47f3a, #f0d68a); color: #fff; padding: 70px 20px; text-align: center; }
    .hero-content { max-width: 700px; margin: 0 auto; }
    .hero-badge { display: inline-block; background: rgba(255,255,255,0.2); padding: 6px 18px; border-radius: 20px; font-size: 0.9rem; margin-bottom: 20px; }
    .hero h1 { font-size: 2.8rem; font-weight: 800; margin-bottom: 14px; text-shadow: 0 2px 20px rgba(0,0,0,0.3); }
    .hero p { font-size: 1.15rem; opacity: 0.92; margin-bottom: 28px; }
    .btn-primary { background: #fff; color: #8b4513; padding: 14px 32px; border-radius: 30px; text-decoration: none; font-weight: 700; }
    
    .section { max-width: 1200px; margin: 0 auto; padding: 50px 20px; }
    .section h2 { font-size: 1.6rem; color: #8b4513; margin-bottom: 20px; padding-left: 14px; border-left: 4px solid #c47f3a; }
    .highlight-box { background: #fff8f0; border: 1px solid #f0d68a; border-radius: 10px; padding: 18px 22px; margin: 16px 0; }
    .highlight-box strong { color: #8b4513; }
    
    .price-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
    .price-table th { background: #8b4513; color: #fff; padding: 12px 16px; text-align: left; }
    .price-table td { padding: 10px 16px; border-bottom: 1px solid var(--border); }
    .price-col { color: #c0392b; font-weight: 700; }
    
    .cta-section { background: linear-gradient(135deg, #0f172a, #1e293b); color: #fff; text-align: center; padding: 64px 20px; }
    .cta-phone { font-size: 2.6rem; font-weight: 800; color: #4ade80; margin: 16px 0; }
    .btn-cta { display: inline-block; background: #22c55e; color: #fff; padding: 14px 32px; border-radius: 28px; text-decoration: none; font-weight: 700; margin: 8px; }
    .btn-cta-white { display: inline-block; background: #fff; color: #0f172a; padding: 14px 32px; border-radius: 28px; text-decoration: none; font-weight: 700; margin: 8px; }
    
    .highlight-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 24px 0; }
    .highlight-card { background: #fff; border-radius: var(--radius); padding: 24px; text-align: center; box-shadow: var(--shadow); }
    .highlight-card .icon { font-size: 2.5rem; margin-bottom: 12px; }
    .highlight-card h3 { font-size: 1.05rem; margin-bottom: 6px; }
    .highlight-card p { font-size: 0.88rem; color: var(--text-light); }
    
    @media (max-width: 768px) { .hero h1 { font-size: 2rem; } .cta-phone { font-size: 2rem; } .highlight-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <Header />
  <main>
    <section class="hero">
      <div class="hero-content">
        <div class="hero-badge">🪷 国家5A级景区 · 世界佛教论坛永久会址</div>
        <h1>灵山大佛导游讲解</h1>
        <p>澜青旅行社专业导游带您领略佛教文化，感受88米青铜大佛的震撼</p>
        <a href="#contact" class="btn-primary">📞 立即预约导游</a>
      </div>
    </section>

    <section class="section">
      <h2>🪷 灵山胜境概况</h2>
      <p>灵山大佛位于无锡太湖之滨，是<strong>世界著名的佛教文化景区</strong>。88米高的青铜释迦牟尼立像，是目前中国最大的青铜佛像之一。景区包含大佛、九龙灌浴、梵宫、五印坛城等精华景点。</p>
    </section>

    <section class="section">
      <h2>✨ 必游亮点</h2>
      <div class="highlight-grid">
        <div class="highlight-card">
          <div class="icon">🗿</div>
          <h3>抱佛脚</h3>
          <p>登顶摸佛脚，祈福平安吉祥</p>
        </div>
        <div class="highlight-card">
          <div class="icon">🐉</div>
          <h3>九龙灌浴</h3>
          <p>大型音乐喷泉表演，再现佛祖诞生</p>
        </div>
        <div class="highlight-card">
          <div class="icon">🏛️</div>
          <h3>梵宫</h3>
          <p>世界级佛教艺术殿堂，金碧辉煌</p>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>💰 导游服务与价格</h2>
      <table class="price-table">
        <thead><tr><th>服务类型</th><th>时长</th><th>人数</th><th>价格</th></tr></thead>
        <tbody>
          <tr><td>散客拼团讲解</td><td>3小时</td><td>20人</td><td class="price-col">¥98/人</td></tr>
          <tr><td>私家导游</td><td>5小时</td><td>6人</td><td class="price-col">¥458/组</td></tr>
          <tr><td>深度文化讲解</td><td>全天</td><td>6人</td><td class="price-col">¥788/组</td></tr>
          <tr><td>祈福专场导游</td><td>4小时</td><td>4人</td><td class="price-col">¥558/组</td></tr>
        </tbody>
      </table>
    </section>

    <section class="cta-section" id="contact">
      <h2>📞 预约澜青导游</h2>
      <p>微信：<strong style="color:#4ade80;">18012361217</strong></p>
      <div class="cta-phone">400-858-0518</div>
      <p style="color:#94a3b8;">支持当天预约 / 节假日正常接单</p>
      <a href="tel:4008580518" class="btn-cta">📞 直接拨打</a>
      <a href="weixin://dl/chat?18012361217" class="btn-cta-white">💬 微信咨询</a>
    </section>
  </main>
  <Footer />
</body>
</html>