---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>无锡包车服务_导游包车一站式_澜青旅行社</title>
  <meta name="description" content="澜青旅行社提供无锡包车服务，导游+车辆一站式安排。5座轿车、7座商务、15座中巴可选，无锡市区、机场接送、景点接送全覆盖。" />
  <meta name="keywords" content="无锡包车,无锡租车,导游包车,机场接送,澜青旅行社" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --primary: #1a6b52; --text: #1e293b; --text-light: #64748b; --bg: #f8fafc; --white: #fff; --border: #e2e8f0; --shadow: 0 4px 24px rgba(0,0,0,0.06); --radius: 12px; }
    body { font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif; color: var(--text); line-height: 1.7; background: var(--bg); }
    
    .hero { background: linear-gradient(160deg, #1a1a2e, #16213e, #0f3460, #533483); color: #fff; padding: 70px 20px; text-align: center; }
    .hero-content { max-width: 700px; margin: 0 auto; }
    .hero-badge { display: inline-block; background: rgba(255,255,255,0.2); padding: 6px 18px; border-radius: 20px; font-size: 0.9rem; margin-bottom: 20px; }
    .hero h1 { font-size: 2.8rem; font-weight: 800; margin-bottom: 14px; }
    .hero p { font-size: 1.15rem; opacity: 0.92; margin-bottom: 28px; }
    .btn-primary { background: #fff; color: #16213e; padding: 14px 32px; border-radius: 30px; text-decoration: none; font-weight: 700; }
    
    .section { max-width: 1200px; margin: 0 auto; padding: 50px 20px; }
    .section h2 { font-size: 1.6rem; color: #16213e; margin-bottom: 20px; padding-left: 14px; border-left: 4px solid #533483; }
    
    .car-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 24px 0; }
    .car-card { background: #fff; border-radius: var(--radius); padding: 28px 20px; text-align: center; box-shadow: var(--shadow); }
    .car-card .icon { font-size: 3rem; margin-bottom: 12px; }
    .car-card h3 { font-size: 1.15rem; margin-bottom: 6px; }
    .car-card .capacity { color: #533483; font-weight: 700; margin-bottom: 4px; }
    .car-card .price { font-size: 1.2rem; color: #c0392b; font-weight: 700; margin-top: 8px; }
    .car-card p { font-size: 0.88rem; color: var(--text-light); }
    
    .service-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .service-item { background: #fff; border-radius: var(--radius); padding: 20px; box-shadow: var(--shadow); display: flex; align-items: center; gap: 14px; }
    .service-item .icon { font-size: 2rem; }
    .service-item h3 { font-size: 1.05rem; }
    .service-item p { font-size: 0.85rem; color: var(--text-light); }
    
    .cta-section { background: linear-gradient(135deg, #0f172a, #1e293b); color: #fff; text-align: center; padding: 64px 20px; }
    .cta-phone { font-size: 2.6rem; font-weight: 800; color: #4ade80; margin: 12px 0; }
    .btn-cta { display: inline-block; background: #22c55e; color: #fff; padding: 14px 32px; border-radius: 28px; text-decoration: none; font-weight: 700; margin: 8px; }
    .btn-cta-white { display: inline-block; background: #fff; color: #0f172a; padding: 14px 32px; border-radius: 28px; text-decoration: none; font-weight: 700; margin: 8px; }
    
    @media (max-width: 768px) { .hero h1 { font-size: 2rem; } .car-grid { grid-template-columns: 1fr; } .service-list { grid-template-columns: 1fr; } .cta-phone { font-size: 2rem; } }
  </style>
</head>
<body>
  <Header />
  <main>
    <section class="hero">
      <div class="hero-content">
        <div class="hero-badge">🚗 导游+车辆一站式服务</div>
        <h1>无锡包车服务</h1>
        <p>澜青旅行社提供多种车型，导游带车全程陪同，省心游玩</p>
        <a href="#contact" class="btn-primary">📞 立即预约包车</a>
      </div>
    </section>

    <section class="section">
      <h2>🚘 可选车型</h2>
      <div class="car-grid">
        <div class="car-card">
          <div class="icon">🚗</div>
          <h3>舒适5座轿车</h3>
          <p class="capacity">👤 适合1-3人</p>
          <p>凯美瑞/帕萨特同级</p>
          <div class="price">¥498/天</div>
        </div>
        <div class="car-card">
          <div class="icon">🚙</div>
          <h3>豪华7座商务</h3>
          <p class="capacity">👤 适合4-6人</p>
          <p>别克GL8同级</p>
          <div class="price">¥698/天</div>
        </div>
        <div class="car-card">
          <div class="icon">🚐</div>
          <h3>15座中巴</h3>
          <p class="capacity">👤 适合7-15人</p>
          <p>丰田考斯特同级</p>
          <div class="price">¥998/天</div>
        </div>
      </div>
      <p style="text-align:center; font-size:0.9rem; color:var(--text-light); margin-top:12px;">* 以上价格含导游服务费，不含油费、过路费、停车费</p>
    </section>

    <section class="section">
      <h2>🗺️ 服务范围</h2>
      <div class="service-list">
        <div class="service-item">
          <span class="icon">🏞️</span>
          <div><h3>景点接送</h3><p>鼋头渚、灵山大佛、拈花湾等全覆盖</p></div>
        </div>
        <div class="service-item">
          <span class="icon">✈️</span>
          <div><h3>机场接送</h3><p>苏南硕放机场/上海虹桥/浦东机场</p></div>
        </div>
        <div class="service-item">
          <span class="icon">🚄</span>
          <div><h3>高铁站接送</h3><p>无锡站/无锡东站/惠山站</p></div>
        </div>
        <div class="service-item">
          <span class="icon">🏨</span>
          <div><h3>酒店接送</h3><p>无锡市区任意酒店上门接送</p></div>
        </div>
      </div>
    </section>

    <section class="section" style="background:#f1f5f9;">
      <h2>💡 为什么选择澜青包车</h2>
      <div style="display:grid; grid-template-columns: repeat(4, 1fr); gap:16px; text-align:center;">
        <div style="background:#fff; padding:20px; border-radius:12px;"><div style="font-size:2rem;">👨‍✈️</div><h3 style="margin:8px 0;">导游兼司机</h3><p style="font-size:0.85rem; color:var(--text-light);">边开车边讲解</p></div>
        <div style="background:#fff; padding:20px; border-radius:12px;"><div style="font-size:2rem;">⏰</div><h3 style="margin:8px 0;">时间灵活</h3><p style="font-size:0.85rem; color:var(--text-light);">不赶行程自由玩</p></div>
        <div style="background:#fff; padding:20px; border-radius:12px;"><div style="font-size:2rem;">💎</div><h3 style="margin:8px 0;">价格透明</h3><p style="font-size:0.85rem; color:var(--text-light);">无隐形消费</p></div>
        <div style="background:#fff; padding:20px; border-radius:12px;"><div style="font-size:2rem;">🛡️</div><h3 style="margin:8px 0;">正规保险</h3><p style="font-size:0.85rem; color:var(--text-light);">车辆全险保障</p></div>
      </div>
    </section>

    <section class="cta-section" id="contact">
      <h2>📞 预约包车服务</h2>
      <p>微信：<strong style="color:#4ade80;">18012361217</strong></p>
      <div class="cta-phone">400-858-0518</div>
      <p>📧 邮箱：<strong style="color:#4ade80;">932168783@qq.com</strong></p>
      <p style="color:#94a3b8; margin-top:8px;">提前预约，确保车型和导游可用</p>
      <a href="tel:4008580518" class="btn-cta">📞 直接拨打</a>
      <a href="mailto:932168783@qq.com" class="btn-cta-white">📧 发送邮件</a>
    </section>
  </main>
  <Footer />
</body>
</html>