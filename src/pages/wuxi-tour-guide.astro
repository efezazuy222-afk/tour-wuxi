---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>无锡导游服务_专业私人导游讲解_澜青旅行社</title>
  <meta name="description" content="澜青旅行社提供无锡本地专业导游服务，持证导游一对一讲解，覆盖鼋头渚、灵山大佛、拈花湾、太湖等全部热门景点。私人定制路线，深度文化讲解。" />
  <meta name="keywords" content="无锡导游,私人导游,导游讲解,无锡旅游,澜青旅行社" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    :root { --primary: #1a6b52; --text: #1e293b; --text-light: #64748b; --bg: #f8fafc; --white: #fff; --border: #e2e8f0; --shadow: 0 4px 24px rgba(0,0,0,0.06); --radius: 12px; }
    body { font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif; color: var(--text); line-height: 1.7; background: var(--bg); }
    
    .hero { background: linear-gradient(160deg, #0f172a, #1e3a5f, #2563eb, #60a5fa); color: #fff; padding: 70px 20px; text-align: center; }
    .hero-content { max-width: 700px; margin: 0 auto; }
    .hero-badge { display: inline-block; background: rgba(255,255,255,0.2); padding: 6px 18px; border-radius: 20px; font-size: 0.9rem; margin-bottom: 20px; }
    .hero h1 { font-size: 2.8rem; font-weight: 800; margin-bottom: 14px; }
    .hero p { font-size: 1.15rem; opacity: 0.92; margin-bottom: 28px; }
    .btn-primary { background: #fff; color: #1e3a5f; padding: 14px 32px; border-radius: 30px; text-decoration: none; font-weight: 700; }
    
    .section { max-width: 1200px; margin: 0 auto; padding: 50px 20px; }
    .section h2 { font-size: 1.6rem; color: #1e3a5f; margin-bottom: 20px; padding-left: 14px; border-left: 4px solid #2563eb; }
    
    .service-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin: 24px 0; }
    .service-card { background: #fff; border-radius: var(--radius); padding: 28px 20px; text-align: center; box-shadow: var(--shadow); }
    .service-card .icon { font-size: 2.5rem; margin-bottom: 12px; }
    .service-card h3 { font-size: 1.1rem; margin-bottom: 8px; }
    .service-card p { font-size: 0.88rem; color: var(--text-light); }
    
    .dest-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .dest-item { background: #fff; border-radius: var(--radius); padding: 20px; box-shadow: var(--shadow); display: flex; align-items: center; gap: 16px; }
    .dest-item .emoji { font-size: 2rem; }
    .dest-item h3 { font-size: 1.1rem; margin-bottom: 4px; }
    .dest-item p { font-size: 0.88rem; color: var(--text-light); }
    
    .cta-section { background: linear-gradient(135deg, #0f172a, #1e293b); color: #fff; text-align: center; padding: 64px 20px; }
    .cta-phone { font-size: 2.6rem; font-weight: 800; color: #4ade80; margin: 12px 0; }
    .btn-cta { display: inline-block; background: #22c55e; color: #fff; padding: 14px 32px; border-radius: 28px; text-decoration: none; font-weight: 700; margin: 8px; }
    .btn-cta-white { display: inline-block; background: #fff; color: #0f172a; padding: 14px 32px; border-radius: 28px; text-decoration: none; font-weight: 700; margin: 8px; }
    
    @media (max-width: 768px) { .hero h1 { font-size: 2rem; } .service-grid { grid-template-columns: 1fr; } .dest-list { grid-template-columns: 1fr; } .cta-phone { font-size: 2rem; } }
  </style>
</head>
<body>
  <Header />
  <main>
    <section class="hero">
      <div class="hero-content">
        <div class="hero-badge">🎖️ 持证导游 · 专业讲解</div>
        <h1>无锡导游服务</h1>
        <p>澜青旅行社专业导游，一对一深度讲解，带您真正读懂无锡</p>
        <a href="#contact" class="btn-primary">📞 立即预约导游</a>
      </div>
    </section>

    <section class="section">
      <h2>👨‍💼 我们的导游服务</h2>
      <p style="margin-bottom:20px;">澜青旅行社拥有多名<strong>持证专业导游</strong>，土生土长无锡人，对无锡的历史文化、街巷美食、摄影机位了如指掌。</p>
      <div class="service-grid">
        <div class="service-card">
          <div class="icon">🎯</div>
          <h3>私人定制路线</h3>
          <p>根据您的兴趣、时间和预算，量身打造专属行程</p>
        </div>
        <div class="service-card">
          <div class="icon">📖</div>
          <h3>深度文化讲解</h3>
          <p>历史典故、建筑美学、佛教文化，听得懂的故事</p>
        </div>
        <div class="service-card">
          <div class="icon">📸</div>
          <h3>网红机位打卡</h3>
          <p>熟知所有隐藏拍摄点，帮您拍出朋友圈大片</p>
        </div>
      </div>
    </section>

    <section class="section" style="background:#f1f5f9;">
      <h2>🏞️ 覆盖景点</h2>
      <div class="dest-list">
        <div class="dest-item"><span class="emoji">🌸</span><div><h3>鼋头渚</h3><p>太湖第一名胜 · 赏樱胜地</p></div></div>
        <div class="dest-item"><span class="emoji">🪷</span><div><h3>灵山大佛</h3><p>88米青铜立佛 · 佛教圣地</p></div></div>
        <div class="dest-item"><span class="emoji">🏮</span><div><h3>拈花湾</h3><p>唐风禅意小镇 · 夜景打卡</p></div></div>
        <div class="dest-item"><span class="emoji">⛵</span><div><h3>太湖风景区</h3><p>三万六千顷烟波浩渺</p></div></div>
        <div class="dest-item"><span class="emoji">🌿</span><div><h3>锡惠公园</h3><p>天下第二泉 · 古典园林</p></div></div>
        <div class="dest-item"><span class="emoji">🏮</span><div><h3>南长街</h3><p>古运河夜游 · 文艺街区</p></div></div>
      </div>
    </section>

    <section class="cta-section" id="contact">
      <h2>📞 预约澜青导游</h2>
      <p>微信：<strong style="color:#4ade80;">18012361217</strong></p>
      <div class="cta-phone">400-858-0518</div>
      <p>📧 邮箱：<strong style="color:#4ade80;">932168783@qq.com</strong></p>
      <p style="color:#94a3b8; margin-top:8px;">支持当天预约 / 节假日正常接单</p>
      <a href="tel:4008580518" class="btn-cta">📞 直接拨打</a>
      <a href="mailto:932168783@qq.com" class="btn-cta-white">📧 发送邮件</a>
    </section>
  </main>
  <Footer />
</body>
</html>